layout(set = 0, binding = 1, rgba32f) readonly uniform image2D normalResourceImage;
layout(set = 0, binding = 2, rg16_snorm) readonly uniform image2D textCoordResourceImage;
layout(set = 0, binding = 3, r8ui) readonly uniform uimage2D materialIndexResourceImage;

