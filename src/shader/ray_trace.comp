  vec4 origin;
  uvec4 numLights;
} ubo;

layout(set = 0, binding = 6) buffer readonly ObjectModel {
  Object objects[];
};

layout(set = 0, binding = 7) buffer readonly ObjectBvhModel {
  BvhNode objectBvhNodes[];
};

layout(set = 0, binding = 8) buffer readonly PrimitiveModel {
  Primitive primitives[];
};

layout(set = 0, binding = 9) buffer readonly PrimitiveBvhModel {
  BvhNode primitiveBvhNodes[];
};

layout(set = 0, binding = 10) buffer readonly VertexModel {
  vec4 vertices[];
};

layout(set = 0, binding = 11) buffer readonly MaterialModel {
  Material materials[];
};

layout(set = 0, binding = 12) buffer readonly TransformationModel {
