#version 460
#extension GL_EXT_mesh_shader : require

#include "struct.glsl"

layout(local_size_x = 128) in;
layout(triangles, max_vertices = 128, max_primitives = 128) out;

layout(location = 0) out vec2 textCoords[];

taskPayloadSharedEXT TaskPayload taskPayload;

layout(set = 0, binding = 5) uniform readonly CameraTransformationBuffer {
	mat4 view;
	mat4 projection;
};

layout(set = 0, binding = 6) uniform readonly TerrainSquareBuffer {
	vec2 totalMinimum;
    vec2 totalMaximum;
};

layout(set = 0, binding = 7) uniform sampler2D heightMapTexture;

uvec3 normalTileIndexing(uint tessellationSize, uint initialIndex) {
	switch(gl_LocalInvocationIndex % 8u) {
		case 0: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + tessellationSize, initialIndex);
		case 1: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 1u, initialIndex);
		case 2: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 1u, initialIndex + 2u);
		case 3: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + tessellationSize + 2u, initialIndex + 2u);
		case 4: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + tessellationSize + 2u, initialIndex + 2u * tessellationSize + 2u);
		case 5: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 2u * tessellationSize + 1u, initialIndex + 2u * tessellationSize + 2u);
		case 6: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 2u * tessellationSize + 1u, initialIndex + 2u * tessellationSize);
		case 7: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + tessellationSize, initialIndex + 2u * tessellationSize);
	}
}

uvec3 leftCrackTileIndexing(uint tessellationSize, uint initialIndex) {
	switch(gl_LocalInvocationIndex % 7u) {
		case 0: return uvec3(initialIndex + tessellationSize + 1u, initialIndex, initialIndex + 2u * tessellationSize);
		case 1: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 1u, initialIndex);
		case 2: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 1u, initialIndex + 2u);
		case 3: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + tessellationSize + 2u, initialIndex + 2u);
		case 4: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + tessellationSize + 2u, initialIndex + 2u * tessellationSize + 2u);
		case 5: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 2u * tessellationSize + 1u, initialIndex + 2u * tessellationSize + 2u);
		case 6: return uvec3(initialIndex + tessellationSize + 1u, initialIndex + 2u * tessellationSize + 1u, initialIndex + 2u * tessellationSize);
	}
}

