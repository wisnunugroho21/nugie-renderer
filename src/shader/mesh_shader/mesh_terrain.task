#version 460
#extension GL_EXT_mesh_shader : require

#include "struct.glsl"

layout(local_size_x = 1) in;

taskPayloadSharedEXT TaskPayload taskPayload;

layout(set = 0, binding = 0) uniform readonly TerrainSquareBuffer {
	vec2 minimum;
    vec2 maximum;
};

void main()
{
    taskPayload.tessellationSize = 5;
    taskPayload.rangeCoordMin = minimum;
    taskPayload.rangeCoordMax = maximum;

    EmitMeshTasksEXT(2, 2, 1);
}