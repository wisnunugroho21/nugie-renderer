#version 460
#extension GL_EXT_mesh_shader : require

#include "core/struct.glsl"

layout(local_size_x = 12, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 8, max_primitives = 12) out;

layout(location = 0) out vec4 fragColor[];

layout (set = 0, binding = 0) buffer readonly VertexBuffer {
  Vertex vertices[];
};

layout (set = 0, binding = 1) buffer readonly PrimitiveBuffer {
  Primitive primitives[];
};

void main()
{
	uint vertexCount = 8;
	uint triangleCount = 12;
	
	SetMeshOutputsEXT(vertexCount, triangleCount);

	if (gl_LocalInvocationIndex < vertexCount) {
		gl_MeshVerticesEXT[gl_LocalInvocationIndex].gl_Position = vertices[gl_LocalInvocationIndex].position;
		fragColor[gl_LocalInvocationIndex] = vec4(1.0f);
	}

	gl_PrimitiveTriangleIndicesEXT[gl_LocalInvocationIndex] = primitives[gl_LocalInvocationIndex].indices.xyz;
}